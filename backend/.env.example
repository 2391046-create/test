# =============================================
# Finance Compass Backend - 환경 변수 설정
# =============================================
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요
# cp .env.example .env

# [필수] Gemini AI API 키
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# [필수] ngrok 인증 토큰
# https://dashboard.ngrok.com/get-started/your-authtoken 에서 발급
NGROK_TOKEN=your_ngrok_token_here

# [선택] XRPL 네트워크 (기본값: 테스트넷)
XRPL_NETWORK_URL=https://s.altnet.rippletest.net:51234

# [선택] 환율 API 키 (없어도 무료 API 자동 사용)
EXCHANGE_RATE_API_KEY=

# [선택] 서버 포트 (기본값: 8000)
PORT=8000
